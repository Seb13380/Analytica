APP_NAME=Analytica
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost:8080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=analytica
DB_USERNAME=analytica
DB_PASSWORD=analytica

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CACHE_STORE=redis
QUEUE_CONNECTION=redis

ANALYTICA_IMPORT_MODE=expert
ANALYTICA_IMPORT_STRICT=true
ANALYTICA_IMPORT_MIN_CONFIDENCE=45
ANALYTICA_IMPORT_HIGH_VALUE_THRESHOLD=20000
ANALYTICA_OCR_MAX_PAGES=180
ANALYTICA_OCR_MAX_PAGES_LIMIT=260
ANALYTICA_OCR_MIN_TX_PER_PAGE=4

CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1026
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123456
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=analytica
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

ANALYTICA_STORAGE_DISK=s3
ANALYTICA_CASE_EXPIRATION_MONTHS=24
ANALYTICA_FILE_ENCRYPTION_KEY=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

ANALYTICA_OCR_URL=http://ocr:8000/ocr
ANALYTICA_OCR_LANG=fra
ANALYTICA_OCR_TIMEOUT=300
ANALYTICA_OCR_FIRST_PAGE=3
ANALYTICA_OCR_MAX_PAGES=6
ANALYTICA_OCR_DPI=250
ANALYTICA_OCR_PSM=6

# --- AI Assistant (optional) ---
# Set ANALYTICA_AI_ENABLED=true and provide OPENAI_API_KEY to enable.
ANALYTICA_AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANALYTICA_AI_MODEL=gpt-4.1-mini
ANALYTICA_AI_MAX_TRANSACTIONS=300
ANALYTICA_AI_TIMEOUT=45
